@page "/login"
@attribute [AllowAnonymous]
@layout Layout.AuthLayout

@using global::UrlShortener.Models
@using global::UrlShortener.ApiServices
@using global::UrlShortener.Auth

@inject IAuthService AuthService
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JsRuntime

<PageTitle>Login</PageTitle>

<MudGrid Justify="Justify.Center" Class="mt-8">
    <MudItem xs="12" sm="6" md="4">
        <MudCard>
            <MudCardHeader>
                <MudText Typo="Typo.h5">Login</MudText>
            </MudCardHeader>
            <MudCardContent>
                <EditForm Model="_model" OnValidSubmit="OnSubmit" FormName="LoginForm">
                    <DataAnnotationsValidator />
                    <MudTextField T="string" Label="Email" @bind-Value="_model.Email" For="() => _model.Email!"
                                  Variant="Variant.Outlined" InputType="InputType.Email" Class="mb-3" />
                    <MudTextField T="string" Label="Password" @bind-Value="_model.Password" For="() => _model.Password!"
                                  Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-3" />
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                               FullWidth="true" Disabled="_isLoading">
                        @if (_isLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Login
                    </MudButton>
                </EditForm>
                <MudText Class="mt-4" Align="Align.Center">
                    Don't have an account? <MudLink Href="/register">Register</MudLink>
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private readonly LoginRequest _model = new();
    private bool _isLoading;

    private async Task OnSubmit()
    {
        _isLoading = true;
        try
        {
            var response = await AuthService.Login(_model);
            await JsRuntime.InvokeVoidAsync("authHelpers.setToken", response.Token);
            AuthStateProvider.NotifyUserAuthentication(response.Token);
            Snackbar.Add($"Welcome back, {response.FullName}!", Severity.Success);
            NavigationManager.NavigateTo("/");
        }
        catch (Refit.ApiException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Snackbar.Add("Invalid email or password", Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Login failed. Please try again.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
