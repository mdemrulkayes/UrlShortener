@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager
@inject Auth.JwtAuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JsRuntime

<MudThemeProvider />
<MudPopoverProvider />
<MudSnackbarProvider />

<MudDialogProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@((_) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">Url Shortener Application</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Class="mr-3">@context.User.Identity?.Name</MudText>
                <MudButton Color="Color.Inherit" OnClick="Logout">Logout</MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Color="Color.Inherit" Href="/login">Login</MudButton>
                <MudButton Color="Color.Inherit" Href="/register">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <AuthorizeView>
                <Authorized>
                    <MudNavLink Href="/" Match="NavLinkMatch.All">Dashboard</MudNavLink>
                    <MudNavLink Href="/urls" Match="NavLinkMatch.Prefix">Urls</MudNavLink>
                </Authorized>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    protected override void OnInitialized()
    {
        AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    async Task Logout()
    {
        await JsRuntime.InvokeVoidAsync("authHelpers.clearToken");
        AuthStateProvider.NotifyUserLogout();
        NavigationManager.NavigateTo("/login", true);
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}